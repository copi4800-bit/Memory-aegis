{
  "name": "truthkeep-memory",
  "version": "10.0.0",
  "description": "TruthKeep Memory: truth-aware memory extension for OpenClaw.",
  "files": [
    "aegis_py/",
    "truthkeep/",
    "bin/",
    "install.sh",
    "requirements.txt",
    "pyproject.toml",
    "README.md",
    "LICENSE",
    "openclaw.plugin.json"
  ],
  "main": "truthkeep/mcp.py",
  "scripts": {
    "postinstall": "bash install.sh",
    "setup": "bash install.sh",
    "test": "pytest tests/",
    "check": "python3 -m truthkeep.install_check"
  },
  "keywords": [
    "memory",
    "truthkeep",
    "governance",
    "mcp",
    "openclaw"
  ],
  "author": "antigravity",
  "license": "MIT",
  "bin": {
    "truthkeep-setup": "./bin/truthkeep-setup",
    "truthkeep-check": "./bin/truthkeep-check",
    "truthkeep-mcp": "./bin/truthkeep-mcp",
    "aegis-setup": "./bin/aegis-setup",
    "aegis-check": "./bin/aegis-check",
    "aegis-mcp": "./bin/aegis-mcp"
  },
  "openclaw": {
    "extensions": [
      {
        "id": "truthkeep-memory",
        "kind": "memory",
        "manifest": "./openclaw.plugin.json",
        "entrypoint": "truthkeep-mcp",
        "onboardingCommand": "truthkeep-setup"
      }
    ]
  }
}
